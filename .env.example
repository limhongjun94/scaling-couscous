# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Gmail address used to send the brief
GMAIL_ADDRESS=your-email@gmail.com

# Gmail App Password (16 chars, no spaces)
# Generate at: https://myaccount.google.com/apppasswords
# Requires 2-Step Verification to be enabled on your Google account.
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Comma-separated list of recipient email addresses
RECIPIENTS=ngkailing03@gmail.com

# Optional: path for the log file (default: market_brief.log)
# LOG_FILE=market_brief.log
